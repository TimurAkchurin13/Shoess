<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Shoes.ViewModels"
        xmlns:models="using:Shoes.Models"
        xmlns:converters="using:Shoes.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="Shoes.Views.ProductsWindow"
        x:DataType="vm:ProductsWindowViewModel"
        Title="ООО Обувь - Каталог товаров"
        Width="1200" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="White"
        Icon="/Assets/Icon.ico">

    <Design.DataContext>
        <vm:ProductsWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с логотипом -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" 
                   Source="/Assets/Icon.ico" 
                   Width="60" 
                   Height="60"
                   Stretch="Uniform"
                   Margin="0,0,15,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Каталог товаров"
                           FontFamily="Times New Roman"
                           FontSize="24"
                           FontWeight="Bold"/>
                <TextBlock Text="ООО Обувь"
                           FontFamily="Times New Roman"
                           FontSize="14"
                           Foreground="Gray"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="8">
                <Button Content="Назад"
                        Background="#E0E0E0"
                        Foreground="Black"
                        FontFamily="Times New Roman"
                        FontSize="14"
                        Padding="12,6"
                        Click="BackButton_Click"
                        Cursor="Hand"/>
                     
            </StackPanel>
        </Grid>

        <!-- Панель фильтров и поиска (только для админа и менеджера) -->
        <Grid Grid.Row="1" Margin="0,0,0,20" IsVisible="{Binding CanFilterAndSearch}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Поиск -->
            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
                <TextBlock Text="Поиск:"
                           FontFamily="Times New Roman"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding SearchText}"
                         FontFamily="Times New Roman"
                         FontSize="14"
                         Watermark="Поиск товара..."/>
            </StackPanel>

            <!-- Категория -->
            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,10,0">
                <TextBlock Text="Категория:"
                           FontFamily="Times New Roman"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          FontFamily="Times New Roman"
                          FontSize="14"/>
            </StackPanel>

            <!-- Производитель -->
            <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,10,0">
                <TextBlock Text="Производитель:"
                           FontFamily="Times New Roman"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Manufacturers}"
                          SelectedItem="{Binding SelectedManufacturer}"
                          FontFamily="Times New Roman"
                          FontSize="14"/>
            </StackPanel>

            <!-- Сортировка -->
            <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,0,0">
                <TextBlock Text="Сортировка:"
                           FontFamily="Times New Roman"
                           FontSize="14"
                           Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding SortOptions}"
                          SelectedItem="{Binding SortOption}"
                          FontFamily="Times New Roman"
                          FontSize="14"/>
            </StackPanel>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="4" 
                        Orientation="Horizontal" 
                        Margin="0,10,0,0">
                <!-- Кнопки для администратора -->
                <Button Content="Добавить"
                        Command="{Binding AddProductCommand}"
                        Background="#00FA9A"
                        Foreground="Black"
                        FontFamily="Times New Roman"
                        FontSize="14"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        IsVisible="{Binding CanEdit}"
                        Cursor="Hand"/>
                <Button Content="Редактировать"
                        Command="{Binding EditProductCommand}"
                        Background="#7FFF00"
                        Foreground="Black"
                        FontFamily="Times New Roman"
                        FontSize="14"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        IsVisible="{Binding CanEdit}"
                        Cursor="Hand"/>
                <Button Content="Удалить"
                        Command="{Binding DeleteProductCommand}"
                        Background="#FFB6C1"
                        Foreground="Black"
                        FontFamily="Times New Roman"
                        FontSize="14"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        IsVisible="{Binding CanEdit}"
                        Cursor="Hand"/>
                
                <Button Content="Обновить"
                        Command="{Binding RefreshCommand}"
                        Background="#E0E0E0"
                        Foreground="Black"
                        FontFamily="Times New Roman"
                        FontSize="14"
                        Padding="15,8"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
        
        
        <!-- Список товаров -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,15"
                                Padding="12"
                                BorderBrush="#C0C0C0"
                                BorderThickness="1.5"
                                CornerRadius="4"
                                Cursor="Hand"
                                Tapped="ProductCard_Tapped">
                            <Border.Background>
                                <MultiBinding>
                                    <Binding Path="StockQuantity"/>
                                    <Binding Path="CurrentDiscount"/>
                                </MultiBinding>
                            </Border.Background>
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="BorderBrush" Value="#00A651"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </Style>
                            </Border.Styles>
                            
                            <Grid ColumnDefinitions="220,*,150">
                                <!-- Фото -->
                                <Border Margin="0,0,15,0"
                                        BorderBrush="#808080"
                                        BorderThickness="1"
                                        Background="#F8F8F8">
                                    <Image Source="{Binding ImageBitmap}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>
                                
                                <!-- Описание -->
                                <StackPanel Grid.Column="1"
                                            Spacing="4">
                                    <TextBlock FontFamily="Times New Roman"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap">
                                        <Run Text="{Binding CategoryName}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding ProductName}"/>
                                    </TextBlock>
                                    
                                    <StackPanel>
                                        <TextBlock FontFamily="Times New Roman" FontSize="14">
                                            <Run Text="Описание товара: "/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Times New Roman"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}"/>
                                    </StackPanel>
                                    
                                    <TextBlock FontFamily="Times New Roman" FontSize="14">
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding ManufacturerName}"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontFamily="Times New Roman" FontSize="14">
                                        <Run Text="Поставщик: "/>
                                        <Run Text="{Binding SupplierName}"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontFamily="Times New Roman" FontSize="14">
                                        <Run Text="Цена: "/>
                                        <Run Text="{Binding Price, StringFormat='{}{0:F2} ₽'}"/>
                                    </TextBlock>
                                    
                                    <TextBlock FontFamily="Times New Roman" FontSize="14">
                                        <Run Text="Единица измерения: "/>
                                        <Run Text="{Binding UnitName}"/>
                                    </TextBlock>
                                    
                                    <!-- Количество на складе, подсветка синим, если товара нет -->
                                    <TextBlock FontFamily="Times New Roman"
                                               FontSize="14"
                                               Foreground="{Binding StockQuantity}">
                                        <Run Text="Количество на складе: "/>
                                        <Run Text="{Binding StockQuantity}"/>
                                    </TextBlock>
                                </StackPanel>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>


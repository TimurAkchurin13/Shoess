<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Shoes.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="Shoes.Views.LoginWindow"
        x:DataType="vm:LoginWindowViewModel"
        Title="ООО Обувь - Авторизация "
        MinWidth="600" MinHeight="400"
        Width="500" Height="600"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="White"
        Icon="/Assets/Icon.ico">

    <Design.DataContext>
        <vm:LoginWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20" MaxWidth="450">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Логотип -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                <Image Source="/Assets/Icon.ico" 
                       Width="120" 
                       Height="120"
                       Stretch="Uniform"/>
                <TextBlock Text="ООО Обувь"
                           FontFamily="Times New Roman"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Форма авторизации -->
            <StackPanel Grid.Row="1" 
                        HorizontalAlignment="Center"
                        Width="350"
                        Margin="0,10,0,20">
            
            <TextBlock Text="Авторизация"
                       FontFamily="Times New Roman"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Логин -->
            <TextBlock Text="Логин:"
                       FontFamily="Times New Roman"
                       FontSize="16"
                       Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username}"
                     FontFamily="Times New Roman"
                     FontSize="16"
                     Watermark="Введите логин"
                     Padding="10"
                     Margin="0,0,0,20"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль:"
                       FontFamily="Times New Roman"
                       FontSize="16"
                       Margin="0,0,0,5"/>
            <TextBox Text="{Binding Password}"
                     FontFamily="Times New Roman"
                     FontSize="16"
                     Watermark="Введите пароль"
                     PasswordChar="*"
                     Padding="10"
                     Margin="0,0,0,10"/>

            <!-- Сообщение об ошибке -->
            <TextBlock Text="{Binding ErrorMessage}"
                       FontFamily="Times New Roman"
                       FontSize="14"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Кнопка входа -->
            <Button Content="Войти"
                    Command="{Binding LoginCommand}"
                    Background="#00FA9A"
                    Foreground="Black"
                    FontFamily="Times New Roman"
                    FontSize="18"
                    FontWeight="Bold"
                    Padding="20,10"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Margin="0,0,0,15"
                    IsEnabled="{Binding !IsLoading}"
                    Cursor="Hand"/>

            <!-- Кнопка входа как гость -->
            <Button Content="Войти как гость"
                    Command="{Binding LoginAsGuestCommand}"
                    Background="#7FFF00"
                    Foreground="Black"
                    FontFamily="Times New Roman"
                    FontSize="16"
                    Padding="20,10"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    IsEnabled="{Binding !IsLoading}"
                    Cursor="Hand"/>
        </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>

